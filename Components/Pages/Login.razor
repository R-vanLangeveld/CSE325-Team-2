@page "/login"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@using Npgsql
@using System
@using System.Security.Cryptography
@using System.Text

<PageTitle>Login</PageTitle>

<h1>Login</h1>

<br><br>

<EditForm Model="@userDto" OnValidSubmit="@ValidFormSubmitted" FormName="LoginUser" method="post" style="display: flex; flex-direction: column; align-items: strech;">
  <fieldset style="display: flex; flex-direction: column; align-items: flex-start; padding-left: 20px; padding-right: 20px; padding-bottom: 20px; padding-top: 10px; border-radius: 15px;">
    <legend style="font-size: x-large;">Login</legend>

    <label for="username" style="font-size: large;">Username:</label>
    <input type="email" required @bind-value="Username" placeholder="exapmleEmail@example.co" title="Any valid email"
    style="font-size: large; min-width: 225px; width: 100%; max-width: 512px;">

    <label for="password" style="font-size: large; margin-top: 20px;">Password:</label>
    <input type="text" required @bind-value="password" pattern="(?=.*\d)(?=.*[a-z])(?=.*[A-Z]).{10,}" title="password must be at least 10 characters long and contain at least 1 of each of the following: lowercase letter, uppercase letter, number"
    style="font-size: large; min-width: 225px; width: 100%; max-width: 512px;">

  </fieldset>
  <input type="submit" value="Login" style="padding: 15px; font-size: x-large; border-radius: 15px;">
</EditForm>

<br><hr><br>

<a href="../registration">
  <button style="font-size: large; padding: 15px; border-radius: 15px;">New User? Click here to register</button>
</a>

@code {
  string password = "";
  string Username { get; set; } = "";

  HolidayPlanner.DTOs.UserDto userDto = new HolidayPlanner.DTOs.UserDto { Name = "placeholder", Username = ""};

  async void ValidFormSubmitted(EditContext editContext) {

    string connectionString = ConfigurationHelper.GetConnectionString(name: "Default");

		try {
			await using NpgsqlDataSource dataSource = NpgsqlDataSource.Create(connectionString);
			await using NpgsqlCommand cmd = dataSource.CreateCommand(commandText: "SELECT \"Id\", \"Username\", \"PasswordHash\" FROM \"Users\" WHERE \"Username\" = @username");

			cmd.Parameters.AddWithValue(parameterName: "@username", Username);

			using NpgsqlDataReader reader = await cmd.ExecuteReaderAsync();
      string passwordFromDB = "";

			while (await reader.ReadAsync()) {
				int id = reader.GetInt32(ordinal: 0);
				string username = reader.GetString(ordinal: 1);
				passwordFromDB = reader.GetString(ordinal: 2);
        userDto.Id = id;
				userDto.Username = username;
			}

      HolidayPlanner.Services.UsersController U_Ctrlr = new HolidayPlanner.Services.UsersController(dataSource);

      if(userDto.Username == Username) {
        string sSourceData;
        byte[] tmpSource;
        byte[] tmpHash;

        sSourceData = password;
        tmpSource = ASCIIEncoding.ASCII.GetBytes(sSourceData);
        tmpHash = MD5.Create().ComputeHash(tmpSource);

        string passwordHash = ByteArrayToString(tmpHash);

        static string ByteArrayToString(byte[] arrInput) {
          int i;
          StringBuilder sOutput = new StringBuilder(arrInput.Length);
          for (i=0;i < arrInput.Length; i++) {
            sOutput.Append(arrInput[i].ToString(format: "X2"));
          }
          return sOutput.ToString();
        }

        if (passwordHash == passwordFromDB) {
          Console.WriteLine(value: "Correct Password");
          Navigation.NavigateTo(uri: $"/profile/{userDto.Id}");
        } else {
          Console.WriteLine(value: "Your password or username is incorrect.");
        }
      } else {
        Console.WriteLine(value: "Your password or username is incorrect.");
      }
		} catch (NpgsqlException ex) {
			Console.WriteLine(value: $"Error: {ex.Message}");
		}

  }
}